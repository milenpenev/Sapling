    const essenceDisabled=!!c?.effect?.disableEssenceUpgrades;
    const essenceClick = essenceDisabled ? 1 : totals.essenceClickMult;
    const essenceScale = essenceDisabled ? 1 : 1 + Math.log10(Math.max(1,(state.totalEssence||0)+1))*totals.clickEssenceScale;
    const comboMult = essenceDisabled ? 1 : manualComboMultiplier();
    const directBase=(1 + totals.clickAdd) * totals.clickMult * essenceClick * challengeRewardTotals().clickMult * (c?.effect?.clickMult||1) * achievementBonuses().click * totals.worldProdMult;
    // Sap Siphon and Heartwood Tempo always use the live passive rate, so the
    // manual gather value changes immediately whenever Sap/sec changes.
    const direct=directBase*essenceScale*comboMult;
    // Sap Siphon is a flat time conversion: exactly N seconds of the current
    // passive Sap/sec. It must not inherit manual-click scaling or combo bonuses.
    const siphon=essenceDisabled ? 0 : currentRate()*totals.clickRateSeconds;
    return {direct,siphon,total:direct+siphon};
  }

  function currentClickGain(){
    return currentClickBreakdown().total;
