    return bought;
  }

  function automationStatusText(){
    ensureAutomation();
    if(state.activeChallenge){
      const c=activeChallenge();
      if(state.automation.claimChallenge && c){
        const remaining=Math.max(0,c.goal-state.runSap);
        return remaining<=0
          ? '<strong>Challenge ready:</strong> claiming on the next automation check.'
          : `<strong>Challenge active:</strong> ${fmt(remaining)} Sap remaining. Reset automation is paused.`;
      }
      return '<strong>Challenge active:</strong> automated Prestige and Ascension are paused.';
    }
    const ascendTarget=Math.max(1,state.automation.ascendMin||1);
    const prestigeTarget=Math.max(1,state.automation.prestigeMin||1);
    if(state.automation.ascend){
      const gain=ascensionGain();
      if(gain>=ascendTarget) return `<strong>Next action:</strong> Ascend for ${fmt(gain)} World Seeds.`;
    }
    if(state.automation.prestige){
      const gain=prestigeGain();
      if(gain>=prestigeTarget) return `<strong>Next action:</strong> Prestige for ${fmt(gain)} Essence.`;
    }
    const waiting=[];
    if(state.automation.ascend) waiting.push(`Ascend ${fmt(ascensionGain())}/${fmt(ascendTarget)}`);
    if(state.automation.prestige) waiting.push(`Prestige ${fmt(prestigeGain())}/${fmt(prestigeTarget)}`);
    return waiting.length
      ? `<strong>Waiting:</strong> ${waiting.join(' • ')}`
      : '<strong>Idle:</strong> enable an automation system to begin.';
  }
  let advancedAutomationAccumulator=0;
  function runAdvancedAutomation(){
    ensureAutomation();
    for(const a of AUTOMATIONS)if(!automationUnlocked(a))state.automation[a.id]=false;
