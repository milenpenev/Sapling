  function addSap(amount){
    if(!Number.isFinite(amount) || amount <= 0) return;
    state.sap += amount;
    state.runSap += amount;
    state.lifetimeSap += amount;
  }

  function prestigeGrossAt(runSap){
    const rawBase = Math.pow(Math.max(0, runSap) / PRESTIGE_BASE, PRESTIGE_EXPONENT);
    const multiplied = rawBase * totals.essenceGainMult * totals.worldEssenceMult * challengeRewardTotals().essenceGainMult * (activeChallenge()?.effect?.essenceGainMult||1) * achievementBonuses().essence;
    const softened = multiplied > PRESTIGE_SOFTCAP_START
      ? PRESTIGE_SOFTCAP_START * Math.pow(multiplied / PRESTIGE_SOFTCAP_START, PRESTIGE_SOFTCAP_POWER)
      : multiplied;
    return Math.floor(softened);
  }
  function prestigeGain(){
    return Math.max(0, prestigeGrossAt(state.runSap) - (Number(state.offlinePrestigeDebt)||0));
  }

  function findMinimumResourceForGain(targetGain, gainAtResource, currentResource){
    if(targetGain <= 0) return 0;
    let low = 0;
    let high = Math.max(1, currentResource || 1);
    let guard = 0;
    while(gainAtResource(high) < targetGain && guard < 220){
      high *= 2;
      guard++;
    }
    if(!Number.isFinite(high) || guard >= 220) return Infinity;
    for(let i=0;i<100;i++){
      const mid=(low+high)/2;
      if(gainAtResource(mid) >= targetGain) high=mid;
      else low=mid;
    }
    return Math.ceil(high);
  }

  function prestigeGainAt(runSap){
    return Math.max(0, prestigeGrossAt(runSap) - (Number(state.offlinePrestigeDebt)||0));
  }

  function sapRequiredForNextEssence(){
