  /* ---------- game loop ---------- */
  let lastTick = performance.now();
  let achievementCheckAccumulator=0;
  function loop(now){
    const dt = Math.min((now - lastTick) / 1000, 1);
    lastTick = now;
    ensureExtendedStats(); ensureAutomation();
    state.stats.totalPlaytime += dt; state.stats.currentRunTime += dt;
    state.stats.highestRate=Math.max(state.stats.highestRate||0,currentRate());
    state.stats.highestClick=Math.max(state.stats.highestClick||0,currentClickGain());
    addSap(currentRate() * dt);
    autoBuyAccumulator += dt;
    advancedAutomationAccumulator += dt;
    achievementCheckAccumulator += dt;
    if(achievementCheckAccumulator>=0.75){achievementCheckAccumulator=0;checkAchievements();}
    if(autoBuyAccumulator >= totals.autoBuyInterval){ autoBuyAccumulator=0; runAutoBuy(); }
    if(advancedAutomationAccumulator>=0.5){advancedAutomationAccumulator=0;runAdvancedAutomation();}
    updateStats();
    updateNodeStates();
    requestAnimationFrame(loop);
  }

  /* ---------- storage compatibility ---------- */
  async function storageGet(){
    try{
      if(window.storage && typeof window.storage.get === 'function'){
        const timeout = new Promise(resolve => setTimeout(() => resolve(null), 1200));
        const result = await Promise.race([window.storage.get(SAVE_KEY, false), timeout]);
        if(result && result.value) return result.value;
      }
    }catch(e){ console.warn('window.storage read failed', e); }
    try{ return localStorage.getItem(SAVE_KEY); }catch(e){ return null; }
  }
  async function storageSet(value){
    let stored = false;
    try{
      if(window.storage && typeof window.storage.set === 'function'){
        const timeout = new Promise(resolve => setTimeout(() => resolve(false), 1200));
        const result = await Promise.race([window.storage.set(SAVE_KEY, value, false).then(()=>true).catch(()=>false), timeout]);
        stored = !!result;
      }
    }catch(e){ console.warn('window.storage write failed', e); }
    try{ localStorage.setItem(SAVE_KEY, value); stored = true; }catch(e){}
    return stored;
  }
  async function storageDelete(){
    try{ if(window.storage && typeof window.storage.delete === 'function') await window.storage.delete(SAVE_KEY); }catch(e){}
    try{ localStorage.removeItem(SAVE_KEY); }catch(e){}
  }

  /* ---------- persistence ---------- */
  let saveTimer;
  async function saveImmediately(){
    state.lastUpdate = Date.now();
    try{ await storageSet(JSON.stringify(state)); }
    catch(e){ console.error('Save failed', e); }
  }
  function save(){
    clearTimeout(saveTimer);
    saveTimer = setTimeout(async () => {
      state.lastUpdate = Date.now();
      try{
        await storageSet(JSON.stringify(state));
      }catch(e){ console.error('Save failed', e); }
    }, 400);
  }

  function formatDuration(seconds){
    seconds=Math.max(0,Math.floor(seconds));
    const h=Math.floor(seconds/3600), m=Math.floor((seconds%3600)/60), s=seconds%60;
    if(h>0) return `${h}h ${m}m ${s}s`;
    if(m>0) return `${m}m ${s}s`;
    return `${s}s`;
  }
  function setLoading(step,progress){
    const stepEl=document.getElementById('loading-step');
    const bar=document.getElementById('loading-progress');
    if(stepEl) stepEl.textContent=step;
    if(bar) bar.style.width=`${Math.max(0,Math.min(100,progress))}%`;
  }
  function setRewardFlow(id,before,gain){
    const el=document.getElementById(id); if(!el) return;
    const after=before+gain;
    el.querySelector('.before').textContent=fmt(before);
    el.querySelector('.after').textContent=fmt(after);
    el.querySelector('.gain').textContent=`(+${fmt(gain)})`;
  }
  function harvestLabel(seconds){
    if(seconds>=6*3600) return '🌲 Legendary harvest!';
    if(seconds>=3600) return '🌳 Excellent growth!';
    if(seconds>=10*60) return '⭐ Great harvest!';
    return '🌱 Fresh growth';
  }
  let pendingStartupRewards={seconds:0,sap:0,essence:0,seeds:0};
  function setOfflineSummary(seconds,sap,essence,seeds){
    document.getElementById('offline-time-label').textContent=`Offline: ${formatDuration(seconds)}`;
    setRewardFlow('offline-sap-reward',state.sap,sap);
    setRewardFlow('offline-essence-reward',state.essence,essence);
    setRewardFlow('offline-world-reward',state.worldSeeds,seeds);
    const badge=document.getElementById('loading-harvest-badge'); if(badge) badge.textContent=harvestLabel(seconds);
  }
  async function animateRewardCollection(rewards, ids, progressId, noteId){
    const duration=1250, start=performance.now();
    const startSap=state.sap, startRun=state.runSap, startLife=state.lifetimeSap;
    const startEss=state.essence, startTotalEss=state.totalEssence;
    const startSeeds=state.worldSeeds, startTotalSeeds=state.totalWorldSeeds;
    return new Promise(resolve=>{
      function frame(now){
        const t=Math.min(1,(now-start)/duration), eased=1-Math.pow(1-t,3);
        const sapNow=rewards.sap*eased, essNow=Math.floor(rewards.essence*eased), seedNow=Math.floor(rewards.seeds*eased);
        state.sap=startSap+sapNow; state.runSap=startRun+sapNow; state.lifetimeSap=startLife+sapNow;
        state.essence=startEss+essNow; state.totalEssence=startTotalEss+essNow;
        state.worldSeeds=startSeeds+seedNow; state.totalWorldSeeds=startTotalSeeds+seedNow;
        setRewardFlow(ids.sap,startSap,sapNow); setRewardFlow(ids.essence,startEss,essNow); setRewardFlow(ids.seeds,startSeeds,seedNow);
        const bar=document.getElementById(progressId); if(bar) bar.style.width=`${t*100}%`;
        const note=document.getElementById(noteId); if(note) note.textContent=t<1?'Applying offline rewards…':'Rewards collected.';
        updateStats(); updateNodeStates();
        if(t<1) requestAnimationFrame(frame); else resolve();
      }
      requestAnimationFrame(frame);
    });
  }
  function finishLoading(){
    setLoading('Offline rewards ready',100);
    const button=document.getElementById('loading-continue');
    button.classList.add('show');
    button.onclick=async()=>{
      button.disabled=true; button.textContent='Collecting…';
      await animateRewardCollection(pendingStartupRewards,{sap:'offline-sap-reward',essence:'offline-essence-reward',seeds:'offline-world-reward'},'loading-progress','loading-note');
      state.offlinePrestigeDebt+=pendingStartupRewards.essence;
      state.offlineAscendDebt+=pendingStartupRewards.seeds;
      await saveImmediately();
      document.getElementById('loading-screen').classList.add('hidden');
    };
  }

  function calculateOfflineRewards(seconds){
    seconds=Math.max(0,Math.min(Number(seconds)||0,8*3600));
    const result={seconds,sap:0,essence:0,seeds:0};
    if(seconds<=1 || !state.settings?.offlineGain) return result;
    recalcTotals();

    // When Auto Prestige is enabled, reproduce its repeated resets offline instead
    // of granting only 20% of one large theoretical prestige calculation.
    const autoPrestigeActive = !!state.automation?.prestige && !state.activeChallenge;
    if(autoPrestigeActive){
      const originalState=state;
      const simulationState=JSON.parse(JSON.stringify(state));
      const startingSap=Number(state.sap)||0;
      const startingEssence=Number(state.essence)||0;
      const startingSeeds=Number(state.worldSeeds)||0;
      let remaining=seconds;
      let guard=0;

      try{
        state=simulationState;
        ensureAutomation();
        recalcTotals();
        const minimumGain=Math.max(1,Math.floor(Number(state.automation.prestigeMin)||1));

        // Event-based simulation: jump directly to the next time the configured
        // prestige gain is reached. Automation checks every 0.5 seconds online,
        // so each event is rounded up to the same interval.
        while(remaining>0.0001 && guard<100000){
          guard++;
          const rate=currentRate();
          if(!Number.isFinite(rate) || rate<=0) break;

          const requiredRunSap=findMinimumResourceForGain(minimumGain,prestigeGainAt,state.runSap);
          if(!Number.isFinite(requiredRunSap)){
            addSap(rate*remaining);
            remaining=0;
            break;
          }

          const missing=Math.max(0,requiredRunSap-state.runSap);
          const rawTime=missing/rate;
          const timeToAutomationCheck=Math.max(0.5,Math.ceil(rawTime/0.5)*0.5);

          if(timeToAutomationCheck>remaining){
            addSap(rate*remaining);
            remaining=0;
            break;
          }

          addSap(rate*timeToAutomationCheck);
          remaining-=timeToAutomationCheck;

          const gain=prestigeGain();
          if(gain<minimumGain){
            // Floating-point safety: advance one more automation interval.
            const extra=Math.min(0.5,remaining);
            if(extra<=0) break;
            addSap(currentRate()*extra);
            remaining-=extra;
            continue;
          }

          state.essence+=gain;
          state.totalEssence+=gain;
          state.offlinePrestigeDebt=0;
          state.prestiges=(Number(state.prestiges)||0)+1;
          state.stats=state.stats||{};
          state.stats.highestPrestigeGain=Math.max(state.stats.highestPrestigeGain||0,gain);
          state.stats.currentRunTime=0;
          state.sap=0;
          state.runSap=0;
          state.purchased=getPrestigeStartingPurchases();
          recalcTotals();
        }

        if(remaining>0 && Number.isFinite(currentRate())) addSap(currentRate()*remaining);
        result.sap=Math.max(0,(Number(state.sap)||0)-startingSap);
        result.essence=Math.max(0,(Number(state.essence)||0)-startingEssence);
        result.seeds=Math.max(0,(Number(state.worldSeeds)||0)-startingSeeds);
      } finally {
        state=originalState;
        recalcTotals();
      }
      return result;
    }

    // Legacy passive offline calculation when Auto Prestige is disabled.
    const beforePrestigeGross=prestigeGrossAt(state.runSap);
    const beforeAscendGross=ascensionGrossAt(state.essence);
    result.sap=currentRate()*seconds;
    const afterPrestigeGross=prestigeGrossAt(state.runSap+result.sap);
    if((state.prestiges>0||state.totalEssence>0) && afterPrestigeGross>beforePrestigeGross){
      result.essence=Math.floor((afterPrestigeGross-beforePrestigeGross)*0.20);
    }
    const afterAscendGross=ascensionGrossAt(state.essence+result.essence);
    if((state.totalWorldSeeds>0||state.worldSeeds>0) && afterAscendGross>beforeAscendGross){
      result.seeds=Math.floor((afterAscendGross-beforeAscendGross)*0.10);
    }
    return result;
  }

  function applyOfflineRewardsInstant(rewards){
    if(rewards.sap>0) addSap(rewards.sap);
    if(rewards.essence>0){ state.essence+=rewards.essence; state.totalEssence+=rewards.essence; state.offlinePrestigeDebt+=rewards.essence; }
    if(rewards.seeds>0){ state.worldSeeds+=rewards.seeds; state.totalWorldSeeds+=rewards.seeds; state.offlineAscendDebt+=rewards.seeds; }
  }

  async function showReturnOverlay(rewards){
    const overlay=document.getElementById('return-overlay');
    if(!overlay) return;
    overlay.classList.add('show');
    const continueButton=document.getElementById('return-continue');
    continueButton.classList.add('show'); continueButton.disabled=false; continueButton.textContent='Collect and continue';
    document.getElementById('return-offline-time').textContent=formatDuration(rewards.seconds);
    document.getElementById('return-progress-bar').style.width='0%';
    document.getElementById('return-note').textContent=state.settings?.offlineGain ? 'Review your rewards, then collect them.' : 'Offline gain is disabled in Settings.';
    const badge=document.getElementById('return-harvest-badge'); if(badge) badge.textContent=harvestLabel(rewards.seconds);
    setRewardFlow('return-sap-reward',state.sap,rewards.sap);
    setRewardFlow('return-essence-reward',state.essence,rewards.essence);
    setRewardFlow('return-world-reward',state.worldSeeds,rewards.seeds);
    return new Promise(resolve=>{
      continueButton.onclick=async()=>{
        continueButton.disabled=true; continueButton.textContent='Collecting…';
        await animateRewardCollection(rewards,{sap:'return-sap-reward',essence:'return-essence-reward',seeds:'return-world-reward'},'return-progress-bar','return-note');
        state.offlinePrestigeDebt+=rewards.essence;
        state.offlineAscendDebt+=rewards.seeds;
        await saveImmediately();
        overlay.classList.remove('show');
        continueButton.classList.remove('show');
        resolve();
      };
    });
  }

  async function load(){
    setLoading('Preparing interface…',8);
    recalcTotals(); buildSvg(); updateNodeStates(); updateStats();
    let offlineSeconds=0, offlineSap=0, offlineEssence=0, offlineSeeds=0;
    try{
      setLoading('Reading save…',20);
      const savedValue = await storageGet();
      if(savedValue){
        const loaded = JSON.parse(savedValue);
        state = Object.assign({ version:11, sap:0, essence:0, totalEssence:0, runSap:0, lifetimeSap:0, prestiges:0, purchased:{seed:true}, essenceUpgrades:{}, worldSeeds:0, totalWorldSeeds:0, worldUpgrades:{}, autoBuyEnabled:false, activeChallenge:null, completedChallenges:{}, achievements:{}, stats:{totalClicks:0}, automation:{sapUpgrades:false,essenceUpgrades:false,worldUpgrades:false,prestige:false,ascend:false,claimChallenge:false,restartChallenge:false,prestigeMin:1,ascendMin:1,lastChallenge:null}, offlinePrestigeDebt:0, offlineAscendDebt:0, settings:{offlineGain:true,essenceSort:'default'}, lastUpdate: Date.now() }, loaded);
        state.version = 11;
        state.totalEssence = Math.max(Number(state.totalEssence)||0, Number(state.essence)||0);
        state.essenceUpgrades = Object.assign({}, state.essenceUpgrades || {});
        state.worldSeeds=Math.max(0,Number(state.worldSeeds)||0); state.totalWorldSeeds=Math.max(state.worldSeeds,Number(state.totalWorldSeeds)||0); state.worldUpgrades=Object.assign({},state.worldUpgrades||{});
        state.purchased = Object.assign({seed:true}, state.purchased || {});
        state.activeChallenge = challengeById[state.activeChallenge] ? state.activeChallenge : null;
        state.completedChallenges = Object.assign({}, state.completedChallenges || {});
        state.settings = Object.assign({offlineGain:true,essenceSort:'default'}, state.settings || {}); ensureExtendedStats(); ensureAutomation();
        state.offlinePrestigeDebt=Math.max(0,Number(state.offlinePrestigeDebt)||0);
        state.offlineAscendDebt=Math.max(0,Number(state.offlineAscendDebt)||0);

        const elapsedMs = Math.max(0,Date.now()-(state.lastUpdate||Date.now()));
        offlineSeconds=Math.min(elapsedMs/1000,8*3600);
        setOfflineSummary(offlineSeconds,0,0,0);
        setLoading(`Calculating ${formatDuration(offlineSeconds)} of offline growth…`,45);
        const startupRewards=calculateOfflineRewards(offlineSeconds);
        offlineSap=startupRewards.sap; offlineEssence=startupRewards.essence; offlineSeeds=startupRewards.seeds;
        pendingStartupRewards=startupRewards;
        ensureExtendedStats(); state.stats.totalOfflineTime+=offlineSeconds; state.stats.longestOfflineTime=Math.max(state.stats.longestOfflineTime||0,offlineSeconds); state.stats.biggestOfflineSap=Math.max(state.stats.biggestOfflineSap||0,startupRewards.sap||0);
        setOfflineSummary(offlineSeconds,offlineSap,offlineEssence,offlineSeeds);
      }else{
        setLoading('Starting a new forest…',70);
      }
    }catch(e){
      console.error('Load failed',e);
      document.getElementById('loading-note').textContent='The save could not be read, so a fresh session was loaded. Your browser console may contain more details.';
    }
    setLoading('Rendering upgrades…',82);
    ensureSettings(); recalcTotals(); buildSvg(); updateNodeStates(); updateStats(); updateSettingsUI();
    state.lastUpdate=Date.now();
    finishLoading();
  }

  load().then(() => {
    lastTick = performance.now();
    checkAchievements();
    renderAchievements(); renderStatistics(); renderAutomation();
    requestAnimationFrame(loop);
    setInterval(save, 5000);
  });

  let tabHiddenAt=null;
  let handlingTabReturn=false;
  document.addEventListener('visibilitychange',async()=>{
    if(document.hidden){
      tabHiddenAt=Date.now();
      await saveImmediately();
      return;
    }
    if(!tabHiddenAt || handlingTabReturn) return;
    const elapsed=Math.min((Date.now()-tabHiddenAt)/1000,8*3600);
    tabHiddenAt=null;
    lastTick=performance.now();
    if(elapsed<2) return;
    handlingTabReturn=true;
    const rewards=calculateOfflineRewards(elapsed);
    ensureExtendedStats(); state.stats.totalOfflineTime+=elapsed; state.stats.longestOfflineTime=Math.max(state.stats.longestOfflineTime||0,elapsed); state.stats.biggestOfflineSap=Math.max(state.stats.biggestOfflineSap||0,rewards.sap||0);
    await showReturnOverlay(rewards);
    state.lastUpdate=Date.now();
    handlingTabReturn=false;
  });

  window.addEventListener('beforeunload', saveImmediately);
</script>
<script>
function exportSave(){
  const json = JSON.stringify(state);
  const encoded = btoa(unescape(encodeURIComponent(json)));
  navigator.clipboard.writeText(encoded).then(() => showToast('Save copied to clipboard')).catch(() => showToast('Clipboard access was blocked'));
}
</script></body>
