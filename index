  function decodeSaveString(encoded){
    const clean = encoded.trim();
    if(!clean) throw new Error('Paste a save string first.');
    const json = decodeURIComponent(escape(atob(clean)));
    const loaded = JSON.parse(json);
    if(!loaded || typeof loaded !== 'object') throw new Error('The save does not contain valid game data.');
    if(!Number.isFinite(Number(loaded.sap)) || !loaded.purchased) throw new Error('The save is missing required fields.');
    return loaded;
  }

