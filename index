  function curvePath(p, c){
    const midY = (p.y + c.y) / 2;
    return `M ${p.x} ${p.y} C ${p.x} ${midY}, ${c.x} ${midY}, ${c.x} ${c.y}`;
  }

  function buildSvg(){
    svg.innerHTML = '';
    const branchLayer = document.createElementNS(svg.namespaceURI,'g');
    const nodeLayer = document.createElementNS(svg.namespaceURI,'g');

    for(const n of NODES){
      if(!n.parent) continue;
      const p = nodeById[n.parent];
      const path = document.createElementNS(svg.namespaceURI,'path');
      path.setAttribute('d', curvePath(p, n));
      path.setAttribute('class','branch-path');
      path.dataset.for = n.id;
      branchLayer.appendChild(path);
    }

    for(const n of NODES){
      const g = document.createElementNS(svg.namespaceURI,'g');
      g.setAttribute('class','node');
      g.dataset.id = n.id;
      g.setAttribute('transform', `translate(${n.x},${n.y})`);

      const circle = document.createElementNS(svg.namespaceURI,'circle');
      circle.setAttribute('class','node-circle');
      circle.setAttribute('r', n.id === 'seed' ? 30 : 26);
      g.appendChild(circle);

      const icon = document.createElementNS(svg.namespaceURI,'text');
      icon.setAttribute('class','node-icon');
      icon.setAttribute('y', 7);
      icon.textContent = n.icon;
      g.appendChild(icon);

      const label = document.createElementNS(svg.namespaceURI,'text');
      label.setAttribute('class','node-label');
      label.setAttribute('y', n.id === 'seed' ? 50 : 46);
      label.textContent = n.name;
      g.appendChild(label);

      if(n.cost > 0){
        const cost = document.createElementNS(svg.namespaceURI,'text');
        cost.setAttribute('class','node-cost');
        cost.setAttribute('y', n.id === 'seed' ? 64 : 60);
        cost.textContent = fmt(nodeCost(n)) + ' sap';
        g.appendChild(cost);
      }

      g.addEventListener('click', () => tryPurchase(n.id));
      g.addEventListener('mousemove', (e) => showTooltip(e, n));
      g.addEventListener('mouseleave', hideTooltip);

      nodeLayer.appendChild(g);
    }

    svg.appendChild(branchLayer);
    svg.appendChild(nodeLayer);
  }

  function updateNodeStates(){
    for(const n of NODES){
      const g = svg.querySelector(`.node[data-id="${n.id}"]`);
