<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Sapling v1.4.8 — Compact Header Buttons</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0b1310;
    --bg-panel:#101c16;
    --bg-panel-2:#0d1713;
    --line:#1f3229;
    --bark:#7a5636;
    --bark-dim:#3c2f22;
    --leaf:#7CFFB2;
    --leaf-dim:#2f5b45;
    --gold:#E8B54D;
    --text:#EAEFE9;
    --text-dim:#8fa398;
    --locked:#243329;
    --danger:#e0725f;
    --radius:14px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:
      radial-gradient(ellipse 900px 500px at 50% 0%, #16261d 0%, transparent 60%),
      var(--bg);
    color:var(--text);
    font-family:'Inter',sans-serif;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:28px 16px 60px;
  }
  .wrap{width:100%;max-width:980px;}

  /* header */
  header{
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    flex-wrap:wrap;
    gap:16px;
    margin-bottom:20px;
  }
  .title{
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size:34px;
    letter-spacing:-0.01em;
    color:var(--text);
  }
  .title .dot{color:var(--leaf);}
  .subtitle{
    font-size:13px;
    color:var(--text-dim);
    margin-top:4px;
    letter-spacing:0.02em;
  }

  /* stat bar */
  .stats{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
  }
  .stat{
    background:var(--bg-panel);
    border:1px solid var(--line);
    border-radius:10px;
    padding:8px 14px;
    min-width:108px;
  }
  .stat .label{font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-dim);}
  .stat .value{font-family:'Fraunces',serif;font-size:19px;font-weight:600;color:var(--gold);margin-top:2px;}
  .stat .value.leafcol{color:var(--leaf);}

  /* main panel */
  .panel{
    background:linear-gradient(180deg,var(--bg-panel) 0%, var(--bg-panel-2) 100%);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:8px;
    position:relative;
    overflow:hidden;
  }
  .panel::before{
    content:'';
    position:absolute;inset:0;
    background:radial-gradient(circle at 50% 100%, rgba(124,255,178,0.06), transparent 55%);
    pointer-events:none;
  }

  svg.tree{width:100%;height:auto;display:block;}
  .branch-path{
    fill:none;
    stroke:var(--bark-dim);
    stroke-width:5;
    stroke-linecap:round;
    transition:stroke 0.4s ease;
  }
  .branch-path.grown{ stroke:var(--bark); }

  .node-circle{
    fill:var(--locked);
    stroke:var(--line);
    stroke-width:2;
    transition:fill 0.25s ease, stroke 0.25s ease, filter 0.25s ease;
  }
  .node.available .node-circle{
    fill:#152a20;
    stroke:var(--leaf-dim);
    cursor:pointer;
  }
  .node.available .node-circle{ animation: pulse 2.2s ease-in-out infinite; }
  .node.purchased .node-circle{
    fill:#173324;
    stroke:var(--leaf);
    filter:drop-shadow(0 0 6px rgba(124,255,178,0.35));
  }
  .node.locked .node-circle{ opacity:0.55; }
  @keyframes pulse{
    0%,100%{ filter:drop-shadow(0 0 0px rgba(124,255,178,0)); }
    50%{ filter:drop-shadow(0 0 9px rgba(124,255,178,0.55)); }
  }
  .node-icon{ font-size:22px; text-anchor:middle; pointer-events:none; user-select:none; }
  .node-label{
    font-family:'Inter',sans-serif;
    font-size:11px;
    font-weight:600;
    text-anchor:middle;
    fill:var(--text-dim);
    pointer-events:none;
    user-select:none;
  }
  .node.purchased .node-label{ fill:var(--text); }
  .node.available .node-label{ fill:var(--leaf); }
  .node-cost{
    font-family:'Inter',sans-serif;
    font-size:10px;
    text-anchor:middle;
    fill:var(--gold);
    pointer-events:none;
    user-select:none;
  }
  .node[data-clickable="true"]:hover .node-circle{ stroke-width:3; }

  /* click-to-gather */
  .gather-row{
    display:flex;
    justify-content:center;
    margin:0 0 18px;
  }
  .gather-btn{
    font-family:'Fraunces',serif;
    font-size:16px;
    font-weight:600;
    color:var(--bg);
    background:linear-gradient(180deg,#98ffc4,var(--leaf));
    border:none;
    border-radius:999px;
    padding:14px 34px;
    cursor:pointer;
    box-shadow:0 4px 0 #3e9a6c, 0 8px 18px rgba(0,0,0,0.35);
    transition:transform 0.08s ease, box-shadow 0.08s ease;
  }
  .gather-btn:active{
    transform:translateY(3px);
    box-shadow:0 1px 0 #3e9a6c, 0 4px 10px rgba(0,0,0,0.35);
  }

  /* footer / controls */
  .footer-row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-top:16px;
    font-size:12px;
    color:var(--text-dim);
  }
  .reset-btn{
    background:none;
    border:1px solid var(--line);
    color:var(--text-dim);
    border-radius:8px;
    padding:6px 12px;
    font-size:12px;
    cursor:pointer;
    font-family:'Inter',sans-serif;
  }
  .reset-btn:hover{ border-color:var(--danger); color:var(--danger); }

  /* tooltip */
  .tooltip{
    position:fixed;
    background:#0f1b15;
    border:1px solid var(--line);
    border-radius:10px;
    padding:10px 12px;
    max-width:220px;
    font-size:12px;
    line-height:1.4;
    pointer-events:none;
    z-index:50;
    opacity:0;
    transition:opacity 0.12s ease;
    box-shadow:0 8px 20px rgba(0,0,0,0.45);
  }
  .tooltip.show{opacity:1;}
  .tooltip .t-name{font-family:'Fraunces',serif;font-weight:600;font-size:14px;color:var(--leaf);margin-bottom:3px;}
  .tooltip .t-desc{color:var(--text-dim);margin-bottom:6px;}
  .tooltip .t-cost{color:var(--gold);font-weight:600;}
  .tooltip .t-state{color:var(--text-dim);font-style:italic;}

  /* toast */
  .toast{
    position:fixed;
    bottom:20px;
    left:50%;
    transform:translateX(-50%) translateY(10px);
    background:#0f1b15;
    border:1px solid var(--leaf-dim);
    color:var(--text);
    padding:10px 18px;
    border-radius:10px;
    font-size:13px;
    opacity:0;
    transition:opacity 0.3s ease, transform 0.3s ease;
    z-index:60;
    pointer-events:none;
  }
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

  .auto-buy-bar{display:flex;justify-content:space-between;align-items:center;gap:12px;margin:0 0 16px;padding:12px 14px;border:1px solid var(--line);border-radius:12px;background:rgba(255,255,255,.025)}
  .auto-buy-bar div{display:flex;flex-direction:column;gap:3px}.auto-buy-bar span{font-size:12px;color:var(--text-dim)}
  #auto-buy-toggle.active{border-color:var(--leaf);color:var(--leaf);background:rgba(124,255,178,.08)}

  /* prestige */
  .prestige-btn{
    background:linear-gradient(180deg,#ffd978,var(--gold));
    border:none;color:#211708;border-radius:8px;padding:7px 14px;
    font-size:12px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;
  }
  .prestige-btn:disabled{opacity:.45;cursor:not-allowed;filter:grayscale(.35);}
  .modal-backdrop{
    position:fixed;inset:0;background:rgba(3,8,6,.76);display:none;
    align-items:center;justify-content:center;padding:18px;z-index:100;
  }
  .modal-backdrop.show{display:flex;}
  .modal{
    width:min(460px,100%);background:linear-gradient(180deg,var(--bg-panel),var(--bg-panel-2));
    border:1px solid var(--line);border-radius:16px;padding:22px;box-shadow:0 24px 70px rgba(0,0,0,.55);
  }
  .modal h2{margin:0 0 6px;font-family:'Fraunces',serif;font-size:26px;}
  .modal p{color:var(--text-dim);font-size:13px;line-height:1.55;margin:0 0 16px;}
  .prestige-preview{border:1px solid var(--line);border-radius:12px;padding:14px;margin:14px 0;background:rgba(255,255,255,.02);}
  .preview-row{display:flex;justify-content:space-between;gap:16px;padding:6px 0;font-size:13px;}
  .preview-row strong{color:var(--gold);}
  .modal-actions{display:flex;justify-content:flex-end;gap:10px;margin-top:18px;}
  .modal-actions button{border-radius:9px;padding:9px 14px;font:600 13px 'Inter',sans-serif;cursor:pointer;}
  .cancel-btn{background:none;border:1px solid var(--line);color:var(--text-dim);}
  .confirm-prestige{background:linear-gradient(180deg,#ffd978,var(--gold));border:none;color:#211708;}
  .confirm-prestige:disabled{opacity:.45;cursor:not-allowed;}
  .import-textarea{width:100%;min-height:150px;resize:vertical;background:#09120e;color:var(--text);border:1px solid var(--line);border-radius:10px;padding:12px;font:12px/1.5 monospace;outline:none;}
  .import-textarea:focus{border-color:var(--leaf-dim);box-shadow:0 0 0 3px rgba(124,255,178,.08);}
  .primary-btn{background:linear-gradient(180deg,#98ffc4,var(--leaf));border:none;color:#0b1310;}

  .top-actions{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin:0 0 18px;}
  .tab-nav{display:flex;gap:8px;margin:0 0 12px;flex-wrap:wrap;}
  .tab-btn{background:var(--bg-panel);border:1px solid var(--line);color:var(--text-dim);border-radius:9px;padding:9px 14px;font:600 13px 'Inter',sans-serif;cursor:pointer;}
  .tab-btn.active{color:var(--leaf);border-color:var(--leaf-dim);background:#152a20;}
  .page{display:none;}
  .page.active{display:block;}
  .essence-page{background:linear-gradient(180deg,var(--bg-panel),var(--bg-panel-2));border:1px solid var(--line);border-radius:var(--radius);padding:22px;}
  .essence-header{display:flex;justify-content:space-between;align-items:flex-start;gap:18px;flex-wrap:wrap;margin-bottom:18px;}
  .essence-header h2{font:600 28px 'Fraunces',serif;margin:0 0 5px;}
  .essence-header p{margin:0;color:var(--text-dim);font-size:13px;max-width:620px;line-height:1.5;}
  .essence-balance{border:1px solid var(--line);border-radius:10px;padding:10px 14px;min-width:150px;text-align:right;}
  .essence-balance span{display:block;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-dim);}
  .essence-balance strong{font:600 22px 'Fraunces',serif;color:var(--gold);}
  .essence-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;}
  .essence-upgrade{border:1px solid var(--line);border-radius:12px;padding:15px;background:rgba(255,255,255,.018);display:flex;flex-direction:column;gap:7px;min-height:150px;}
  .essence-upgrade.locked{opacity:.55;}
  .essence-upgrade.purchased{border-color:var(--leaf-dim);background:rgba(124,255,178,.055);}
  .essence-upgrade h3{font:600 18px 'Fraunces',serif;margin:0;color:var(--leaf);}
  .essence-upgrade p{margin:0;color:var(--text-dim);font-size:12px;line-height:1.45;flex:1;}
  .essence-upgrade .requirement{font-size:11px;color:var(--text-dim);}
  .essence-buy{border:none;border-radius:8px;padding:8px 11px;background:linear-gradient(180deg,#ffd978,var(--gold));color:#211708;font:700 12px 'Inter',sans-serif;cursor:pointer;}
  .essence-buy:disabled{opacity:.45;cursor:not-allowed;filter:grayscale(.3);}

  .challenge-page{background:linear-gradient(180deg,var(--bg-panel),var(--bg-panel-2));border:1px solid var(--line);border-radius:var(--radius);padding:22px;}
  .challenge-header{display:flex;justify-content:space-between;gap:18px;align-items:flex-start;flex-wrap:wrap;margin-bottom:18px;}
  .challenge-header h2{font:600 28px 'Fraunces',serif;margin:0 0 5px;}
  .challenge-header p{margin:0;color:var(--text-dim);font-size:13px;line-height:1.5;max-width:650px;}
  .challenge-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;}
  .challenge-card{border:1px solid var(--line);border-radius:12px;padding:16px;background:rgba(255,255,255,.018);display:flex;flex-direction:column;gap:9px;min-height:210px;}
  .challenge-card.active{border-color:var(--gold);box-shadow:0 0 0 2px rgba(232,181,77,.08) inset;}
  .challenge-card.completed{border-color:var(--leaf-dim);background:rgba(124,255,178,.05);}
  .challenge-card.locked{opacity:.58;border-style:dashed;filter:saturate(.65);}
  .challenge-card.locked h3{color:var(--text-dim);}
  .challenge-card h3{font:600 19px 'Fraunces',serif;margin:0;color:var(--gold);}
  .challenge-card p{font-size:12px;color:var(--text-dim);line-height:1.5;margin:0;}
  .challenge-meta{font-size:12px;border-top:1px solid var(--line);padding-top:8px;display:grid;gap:5px;}
  .challenge-actions{margin-top:auto;display:flex;gap:8px;flex-wrap:wrap;}
  .challenge-btn{border:none;border-radius:8px;padding:9px 12px;background:linear-gradient(180deg,#ffd978,var(--gold));color:#211708;font:700 12px 'Inter',sans-serif;cursor:pointer;}
  .challenge-btn.secondary{background:none;border:1px solid var(--line);color:var(--text-dim);}
  .challenge-btn:disabled{opacity:.45;cursor:not-allowed;}
  .active-challenge-banner{display:none;margin:0 0 14px;border:1px solid var(--gold);border-radius:10px;padding:10px 14px;background:rgba(232,181,77,.07);font-size:12px;}
  .active-challenge-banner.show{display:flex;justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap;}


  /* achievements */
  .achievement-page{padding:18px}.achievement-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}.achievement-summary>div{background:rgba(255,255,255,.025);border:1px solid var(--line);border-radius:10px;padding:12px}.achievement-summary span{display:block;color:var(--text-dim);font-size:11px;text-transform:uppercase;letter-spacing:.07em}.achievement-summary strong{display:block;margin-top:5px;font-family:'Fraunces',serif;font-size:22px;color:var(--gold)}.achievement-progress{height:10px;border:1px solid var(--line);border-radius:999px;background:#08120d;overflow:hidden;margin:8px 0 18px}.achievement-progress>div{height:100%;width:0;background:linear-gradient(90deg,var(--leaf-dim),var(--leaf));transition:width .35s ease}.achievement-category{margin:18px 0 8px;font-family:'Fraunces',serif;font-size:18px}.achievement-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:9px}.achievement-card{display:grid;grid-template-columns:42px 1fr;gap:10px;align-items:center;border:1px solid var(--line);border-radius:10px;padding:10px;background:rgba(255,255,255,.018);opacity:.62}.achievement-card.unlocked{opacity:1;border-color:#416b55;background:linear-gradient(135deg,rgba(124,255,178,.09),rgba(232,181,77,.035))}.achievement-icon{width:38px;height:38px;display:grid;place-items:center;border-radius:9px;background:#0b1711;border:1px solid var(--line);font-size:20px}.achievement-card.unlocked .achievement-icon{border-color:var(--leaf-dim);box-shadow:0 0 12px rgba(124,255,178,.14)}.achievement-card h3{font-size:13px;margin:0 0 3px}.achievement-card p{font-size:11px;color:var(--text-dim);margin:0 0 5px;line-height:1.35}.achievement-reward{font-size:10px;color:var(--gold)}.achievement-popup{position:fixed;right:18px;top:18px;width:min(340px,calc(100vw - 36px));z-index:200;background:rgba(9,20,14,.96);border:1px solid var(--leaf-dim);border-radius:12px;padding:13px 15px;box-shadow:0 16px 42px rgba(0,0,0,.5);transform:translateX(120%);opacity:0;transition:.3s ease}.achievement-popup.show{transform:translateX(0);opacity:1}.achievement-popup small{color:var(--gold);text-transform:uppercase;letter-spacing:.08em}.achievement-popup strong{display:block;margin-top:5px;font-family:'Fraunces',serif;font-size:18px}.achievement-popup span{display:block;color:var(--text-dim);font-size:12px;margin-top:3px}
  @media(max-width:700px){.achievement-grid{grid-template-columns:1fr}.achievement-summary{grid-template-columns:1fr}}

  @media (max-width:600px){
    .title{font-size:26px;}
    .stat{min-width:90px;padding:6px 10px;}
    .essence-grid,.challenge-grid{grid-template-columns:1fr;}
  }

  /* v0.9 dashboard layout */
  body{display:block;padding:0;background:radial-gradient(circle at 50% -10%,#183527 0,#07110d 52%,#040906 100%);overflow-x:hidden;}
  .game-shell{width:100%;max-width:1700px;margin:0 auto;padding:10px;}
  .command-bar{display:grid;grid-template-columns:auto minmax(520px,1fr) auto;align-items:center;gap:14px;margin:0 0 10px;padding:10px 12px;background:rgba(8,18,13,.94);border:1px solid #18392b;border-radius:10px;box-shadow:0 10px 30px rgba(0,0,0,.3);position:sticky;top:0;z-index:20;backdrop-filter:blur(12px)}
  .brand-block{min-width:145px}.title{font-size:28px}.subtitle{font-size:11px}.resource-strip{display:grid;grid-template-columns:repeat(4,minmax(105px,1fr));border:1px solid #173427;border-radius:8px;overflow:hidden}.resource-item{display:flex;align-items:center;gap:9px;padding:8px 12px;border-right:1px solid #173427;min-height:64px;background:rgba(255,255,255,.015)}.resource-item:last-child{border-right:0}.resource-icon{font-size:25px}.resource-item div{display:flex;flex-direction:column;min-width:0}.resource-item small{color:#8fa398;font-size:10px;text-transform:uppercase;letter-spacing:.06em}.resource-item strong{font:600 20px 'Fraunces',serif;color:#e8b54d;white-space:nowrap}.resource-item em{font-style:normal;color:#6f8e7d;font-size:10px;white-space:nowrap}.sap-resource strong,.sap-resource em{color:#7cffb2}.essence-resource strong{color:#8bb9ff}.world-resource strong{color:#d9a0ff}
  .command-actions{display:flex;gap:5px;align-items:stretch;flex-wrap:nowrap;min-width:0}.action-stack{display:flex;flex-direction:column;gap:4px;min-width:185px}.action-stack>button{width:100%;flex:1}.action-next{display:block;min-height:28px;padding:4px 7px;border:1px solid #243f33;border-radius:6px;background:#08120d;color:#8fa398;font-size:9px;line-height:1.25;text-align:center}.action-next strong{color:#e8b54d;font-weight:600}.gather-btn,.prestige-btn,.ascend-top-btn{border-radius:7px;min-height:58px;padding:8px 14px;font:600 13px 'Inter',sans-serif;box-shadow:none}.icon-btn{border-radius:7px;width:42px;min-width:42px;height:42px;min-height:42px;padding:0;font:600 18px 'Inter',sans-serif;box-shadow:none;align-self:center;flex:0 0 42px}.gather-btn{display:flex;flex-direction:column;justify-content:center;min-width:145px}.gather-btn span{font-size:11px;font-weight:500;margin-top:3px}.prestige-btn{min-width:175px}.ascend-top-btn{border:1px solid #315243;background:#101a15;color:#9bb0a5;cursor:pointer}.icon-btn{background:#101a15;color:#d4ded8;border:1px solid #294237;font-size:18px;cursor:pointer}.icon-btn:hover,.ascend-top-btn:hover{border-color:#7cffb2;color:#7cffb2}
  .workspace{display:grid;grid-template-columns:minmax(0,1fr) 390px;gap:12px;align-items:start}.main-stage{min-width:0;background:rgba(7,16,11,.75);border:1px solid #19382b;border-radius:10px;overflow:hidden}.tab-nav{margin:0;padding:0 14px;border-bottom:1px solid #19382b;background:rgba(10,22,16,.94);gap:0}.tab-btn{border:0;border-radius:0;background:none;padding:15px 18px;border-bottom:2px solid transparent}.tab-btn.active{background:linear-gradient(180deg,rgba(124,255,178,.08),transparent);border-color:transparent;border-bottom-color:#7cffb2}.mini-open.tab-btn{padding:4px 9px;border:1px solid currentColor;border-radius:6px;font-size:10px}
  .panel,.essence-page,.challenge-page{border:0;border-radius:0;background:linear-gradient(180deg,#08150f,#07110d);min-height:700px}.tree-panel{padding:0;overflow:auto;position:relative}.tree-watermark{position:absolute;inset:15% 20%;display:grid;place-items:center;font-size:420px;filter:grayscale(1);opacity:.025;pointer-events:none}.tree{min-width:850px;position:relative;z-index:1}.node-circle{r:24}.node-icon{font-size:21px}.node-label{font-size:11px}.node-cost{font-size:10px}.branch-path{stroke-width:4}
  .stage-footer{display:flex;justify-content:space-between;padding:9px 12px;color:#71877b;font-size:11px;border-top:1px solid #19382b;background:#08120d}
