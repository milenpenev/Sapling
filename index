  function recalcTotals(){
    let prodAdd = 0;   // no passive production until First Sprout is purchased
    let prodMult = 1;
    let clickAdd = 0;
    let clickMult = 1;
    for(const n of NODES){
      if(!state.purchased[n.id] || !n.effect) continue;
      if(n.effect.type === 'prod_add')   prodAdd  += n.effect.value;
      if(n.effect.type === 'prod_mult')  prodMult *= n.effect.value;
      if(n.effect.type === 'click_add')  clickAdd += n.effect.value;
      if(n.effect.type === 'click_mult') clickMult*= n.effect.value;
    }
    let essenceProdMult=1, essenceClickMult=1, essenceGainMult=1, sapCostMult=1, autoBuyUnlocked=false, autoBuyInterval=1, autoBuyBatch=1, clickRateSeconds=0, clickEssenceScale=0, comboPerStack=0, comboMax=0, comboWindow=0;
    for(const u of ESSENCE_UPGRADES){
      if(!state.essenceUpgrades[u.id] || !u.effect) continue;
      if(u.effect.type==='global_prod_mult') essenceProdMult*=u.effect.value;
      if(u.effect.type==='global_click_mult') essenceClickMult*=u.effect.value;
      if(u.effect.type==='essence_gain_mult') essenceGainMult*=u.effect.value;
      if(u.effect.type==='sap_cost_mult') sapCostMult*=u.effect.value;
      if(u.effect.type==='auto_buy') autoBuyUnlocked=true;
      if(u.effect.type==='auto_buy_speed') autoBuyInterval*=u.effect.value;
      if(u.effect.type==='auto_buy_batch') autoBuyBatch=Math.max(autoBuyBatch,u.effect.value);
      if(u.effect.type==='click_rate_seconds') clickRateSeconds+=u.effect.value;
      if(u.effect.type==='click_essence_scale') clickEssenceScale+=u.effect.value;
      if(u.effect.type==='click_combo'){
        comboPerStack=Math.max(comboPerStack,u.effect.perStack||0);
        comboMax=Math.max(comboMax,u.effect.maxStacks||0);
        comboWindow=Math.max(comboWindow,u.effect.window||0);
      }
      if(u.effect.comboMax) comboMax=Math.max(comboMax,u.effect.comboMax);
    }
    let worldProdMult=1, worldEssenceMult=1, worldSeedMult=1, worldAutoBuy=false, startEssence=0;
    const c=activeChallenge();
    if(!c?.effect?.disableWorldUpgrades){
      for(const u of WORLD_UPGRADES){
        if(!state.worldUpgrades?.[u.id]) continue;
        if(u.effect.type==='world_prod_mult') worldProdMult*=u.effect.value;
        if(u.effect.type==='world_essence_mult') worldEssenceMult*=u.effect.value;
        if(u.effect.type==='world_seed_mult') worldSeedMult*=u.effect.value;
        if(u.effect.type==='world_auto_buy') worldAutoBuy=true;
        if(u.effect.type==='start_essence') startEssence=Math.max(startEssence,u.effect.value);
      }
    }
    autoBuyUnlocked = autoBuyUnlocked || worldAutoBuy;
    if(c?.effect?.disableAutoBuy) autoBuyUnlocked=false;
    if(!autoBuyUnlocked) state.autoBuyEnabled=false;
    totals = { prodAdd, prodMult, clickAdd, clickMult, essenceProdMult, essenceClickMult, essenceGainMult, sapCostMult, autoBuyUnlocked, autoBuyInterval, autoBuyBatch, worldProdMult, worldEssenceMult, worldSeedMult, worldAutoBuy, startEssence, clickRateSeconds, clickEssenceScale, comboPerStack, comboMax, comboWindow };
